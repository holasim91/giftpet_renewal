<script>
        function switchTab(tab) {
            const savedTab = document.getElementById('tab-saved');
            const newTab = document.getElementById('tab-new');
            const savedContent = document.getElementById('saved-address-content');
            const newContent = document.getElementById('new-address-content');

            if (tab === 'saved') {
                savedTab.classList.add('active-tab');
                savedTab.classList.remove('text-on-surface-variant');
                newTab.classList.remove('active-tab');
                newTab.classList.add('text-on-surface-variant');
                savedContent.classList.remove('hidden');
                newContent.classList.add('hidden');
            } else {
                newTab.classList.add('active-tab');
                newTab.classList.remove('text-on-surface-variant');
                savedTab.classList.remove('active-tab');
                savedTab.classList.add('text-on-surface-variant');
                newContent.classList.remove('hidden');
                savedContent.classList.add('hidden');
            }
        }

        function toggleCustomMemo(value) {
            const customField = document.getElementById('custom-memo');
            if (value === 'custom') {
                customField.classList.remove('hidden');
                customField.focus();
            } else {
                customField.classList.add('hidden');
            }
        }

        // Simple scroll shadow logic for header
        window.addEventListener('scroll', () => {
            const header = document.querySelector('header');
            if (window.scrollY > 10) {
                header.classList.add('shadow-sm');
                header.classList.add('bg-white/80');
                header.classList.add('backdrop-blur-md');
            } else {
                header.classList.remove('shadow-sm');
                header.classList.remove('bg-white/80');
                header.classList.remove('backdrop-blur-md');
            }
        });
    </script>
