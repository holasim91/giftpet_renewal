<script>
        function switchTab(type) {
            const tabSaved = document.getElementById('tab-saved');
            const tabNew = document.getElementById('tab-new');
            const contentSaved = document.getElementById('content-saved');
            const contentNew = document.getElementById('content-new');

            if (type === 'saved') {
                tabSaved.classList.add('border-primary', 'text-primary');
                tabSaved.classList.remove('border-transparent', 'text-on-surface-variant');
                tabNew.classList.remove('border-primary', 'text-primary');
                tabNew.classList.add('border-transparent', 'text-on-surface-variant');
                contentSaved.classList.remove('hidden');
                contentNew.classList.add('hidden');
            } else {
                tabNew.classList.add('border-primary', 'text-primary');
                tabNew.classList.remove('border-transparent', 'text-on-surface-variant');
                tabSaved.classList.remove('border-primary', 'text-primary');
                tabSaved.classList.add('border-transparent', 'text-on-surface-variant');
                contentNew.classList.remove('hidden');
                contentSaved.classList.add('hidden');
            }
        }

        function toggleCustomMemo(select) {
            const container = document.getElementById('custom-memo-container');
            if (select.value === 'custom') {
                container.classList.remove('hidden');
                container.classList.add('animate-fade-in-down');
            } else {
                container.classList.add('hidden');
            }
        }
    </script>
<style>
        @keyframes fade-in-down {
            from {
                opacity: 0;
                transform: translateY(-10px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }
        .animate-fade-in-down {
            animation: fade-in-down 0.3s ease-out forwards;
        }
